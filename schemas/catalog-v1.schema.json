{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "catalog-v1",
  "title": "Catalog v1",
  "description": "Schema for catalog.json — the published pack index.",
  "type": "object",
  "required": ["format", "schemaVersion", "updatedAt", "packs"],
  "additionalProperties": false,
  "properties": {
    "format": {
      "type": "string",
      "enum": ["nearby-guide-index"]
    },
    "schemaVersion": {
      "type": "integer",
      "enum": [1]
    },
    "updatedAt": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$"
    },
    "packs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["packId", "version", "title", "subtitle", "region", "contentLanguage", "minAppVersionCode", "compact", "complete"],
        "additionalProperties": false,
        "properties": {
          "packId": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"},
          "version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
          "title": {"type": "string", "minLength": 1},
          "subtitle": {"type": "string", "minLength": 1},
          "region": {
            "type": "object",
            "required": ["countryCode", "countryName", "adminAreaLevel1"],
            "properties": {
              "countryCode": {"type": "string", "pattern": "^[A-Z]{2}$"},
              "countryName": {"type": "string", "minLength": 1},
              "adminAreaLevel1": {"type": "string", "minLength": 1}
            }
          },
          "contentLanguage": {"type": "string", "minLength": 2},
          "minAppVersionCode": {"type": "integer", "minimum": 1},
          "guidePointCount": {"type": "integer", "minimum": 0},
          "compact": {"$ref": "#/definitions/packAsset"},
          "complete": {"$ref": "#/definitions/packAsset"}
        }
      }
    }
  },
  "definitions": {
    "packAsset": {
      "type": "object",
      "required": ["filename", "url", "bytes", "sha256"],
      "additionalProperties": false,
      "properties": {
        "filename": {"type": "string", "minLength": 1},
        "url": {"type": "string", "pattern": "^https?://"},
        "bytes": {"type": "integer", "minimum": 0},
        "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
      }
    }
  }
}
