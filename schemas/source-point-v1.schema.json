{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "source-point-v1",
  "title": "Source Point v1",
  "description": "Schema for point YAML files in the regions/.../points/ directories.",
  "type": "object",
  "required": ["schemaVersion", "point", "ratingEvidence", "sources", "review"],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "enum": [1]
    },
    "point": {
      "type": "object",
      "required": [
        "id", "parentId", "kind", "title", "summary", "narration",
        "observationPrompt", "countryCode", "adminAreaLevel1", "hierarchy",
        "tagGroups", "indoor", "location", "trigger", "locationHint"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
        },
        "parentId": {
          "type": ["string", "null"]
        },
        "kind": {
          "type": "string",
          "enum": ["region", "attraction", "venue", "zone", "artwork", "exhibit", "person", "view"]
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "narration": {
          "type": "string",
          "minLength": 1
        },
        "observationPrompt": {
          "type": "string",
          "minLength": 1
        },
        "countryCode": {
          "type": "string",
          "pattern": "^[A-Z]{2}$"
        },
        "adminAreaLevel1": {
          "type": "string",
          "minLength": 1
        },
        "hierarchy": {
          "type": "array",
          "items": {"type": "string"},
          "minItems": 1
        },
        "tagGroups": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "label", "tags"],
            "additionalProperties": false,
            "properties": {
              "id": {"type": "string", "minLength": 1},
              "label": {"type": "string", "minLength": 1},
              "tags": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["id", "label"],
                  "additionalProperties": false,
                  "properties": {
                    "id": {"type": "string", "minLength": 1},
                    "label": {"type": "string", "minLength": 1}
                  }
                }
              }
            }
          }
        },
        "indoor": {
          "type": "boolean"
        },
        "location": {
          "type": "object",
          "required": ["latitude", "longitude"],
          "additionalProperties": false,
          "properties": {
            "latitude": {
              "type": "number",
              "minimum": -90,
              "maximum": 90
            },
            "longitude": {
              "type": "number",
              "minimum": -180,
              "maximum": 180
            }
          }
        },
        "trigger": {
          "type": "object",
          "required": ["radiusMeters", "dwellMillis", "rearmDistanceMeters"],
          "additionalProperties": false,
          "properties": {
            "radiusMeters": {
              "type": "number",
              "exclusiveMinimum": 0
            },
            "dwellMillis": {
              "type": "integer",
              "minimum": 0
            },
            "rearmDistanceMeters": {
              "type": "number",
              "exclusiveMinimum": 0
            }
          }
        },
        "locationHint": {
          "type": ["string", "null"]
        },
        "googleMapsUrl": {
          "type": ["string", "null"],
          "format": "uri"
        }
      }
    },
    "ratingEvidence": {
      "type": "object",
      "required": ["rubricVersion", "significance", "distinctiveness", "interpretability", "visitorValue", "evidenceQuality", "final"],
      "additionalProperties": false,
      "properties": {
        "rubricVersion": {
          "type": "integer",
          "minimum": 1
        },
        "significance": {"$ref": "#/definitions/ratingDimension"},
        "distinctiveness": {"$ref": "#/definitions/ratingDimension"},
        "interpretability": {"$ref": "#/definitions/ratingDimension"},
        "visitorValue": {"$ref": "#/definitions/ratingDimension"},
        "evidenceQuality": {"$ref": "#/definitions/ratingDimension"},
        "final": {
          "type": "number",
          "minimum": 0,
          "maximum": 5
        }
      }
    },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "title", "publisher", "url", "accessedAt", "language", "supports"],
        "additionalProperties": false,
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "title": {"type": "string", "minLength": 1},
          "publisher": {"type": "string", "minLength": 1},
          "url": {"type": "string", "pattern": "^https?://"},
          "accessedAt": {"type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"},
          "language": {"type": "string", "minLength": 2},
          "supports": {
            "type": "array",
            "minItems": 1,
            "items": {"type": "string", "minLength": 1}
          }
        }
      }
    },
    "media": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "type", "sourceUrl", "creator", "license", "licenseUrl", "accessedAt", "originalSha256", "compactPath", "completePath"],
        "additionalProperties": false,
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "type": {"type": "string", "enum": ["image", "video", "audio"]},
          "sourceUrl": {"type": "string", "pattern": "^https?://"},
          "creator": {"type": "string", "minLength": 1},
          "license": {"type": "string", "minLength": 1},
          "licenseUrl": {"type": "string", "pattern": "^https?://"},
          "accessedAt": {"type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"},
          "originalSha256": {"type": ["string", "null"]},
          "compactPath": {"type": "string", "minLength": 1},
          "completePath": {"type": "string", "minLength": 1}
        }
      }
    },
    "review": {
      "type": "object",
      "required": ["status", "checkedAt", "notes"],
      "additionalProperties": false,
      "properties": {
        "status": {
          "type": "string",
          "enum": ["draft", "review", "approved", "rejected"]
        },
        "checkedAt": {
          "type": "string",
          "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
        },
        "notes": {
          "type": "array",
          "items": {"type": "string"}
        }
      }
    }
  },
  "definitions": {
    "ratingDimension": {
      "type": "object",
      "required": ["score", "note", "sources"],
      "additionalProperties": false,
      "properties": {
        "score": {
          "type": "integer",
          "minimum": 0,
          "maximum": 5
        },
        "note": {
          "type": "string",
          "minLength": 1
        },
        "sources": {
          "type": "array",
          "items": {"type": "string"}
        }
      }
    }
  }
}
