{"format":"nearby-guide-viewer-data","packs":[{"packId":"jp-miyakojima","title":"宮古島","subtitle":"沖繩碧海與珊瑚礁","version":"1.0.4","region":{"countryCode":"JP","countryName":"日本","adminAreaLevel1":"沖縄県"},"points":[{"id":"jp-miyakojima-17end-beach","title":"下地島17エンド","summary":"17ENDは下地島空港滑走路17號跑道終點延伸至海灘的特殊觀景點，旅客可在白沙灘上仰望飛機從頭頂僅數十公尺低空飛越降落，是社群媒體上極具話題性的宮古島絕景。","lat":24.8421,"lng":125.1406,"googleMapsUrl":"https://maps.google.com/maps?q=24.8421,125.1406","indoor":false,"tags":[],"mediaCount":0,"mediaSourceUrl":null,"rating":null,"admissionFree":null,"triggerRadiusM":75.0},{"id":"jp-miyakojima-aragusuku-beach","title":"新城海岸","summary":"新城海岸（アラスキビーチ）是宮古島東岸開發度最低的天然海灘之一，珊瑚礁保存完好，海水清澈見底，是逃離人群的靜謐浮潛勝地。","lat":24.7598523,"lng":125.4248602,"googleMapsUrl":"https://maps.google.com/maps?q=24.7598523,125.4248602","indoor":false,"tags":[],"mediaCount":0,"mediaSourceUrl":null,"rating":null,"admissionFree":null,"triggerRadiusM":75.0},{"id":"jp-miyakojima-awamori-distillery","title":"多良川酒造","summary":"多良川酒造是宮古島具代表性的泡盛釀造廠，以宮古島天然地下水及長期古酒（クース）工藝聞名，提供工廠參觀與品酒體驗，是深入了解琉球蒸餾酒文化的絕佳去處。","lat":24.7309,"lng":125.3523,"googleMapsUrl":"https://maps.google.com/maps?q=24.7309,125.3523","indoor":true,"tags":[],"mediaCount":0,"mediaSourceUrl":null,"rating":null,"admissionFree":null,"triggerRadiusM":75.0},{"id":"jp-miyakojima-biyandam-viewpoint","title":"ビャクダン山展望台","summary":"ビャクダン山是宮古島的最高點，海拔約113公尺，展望台可俯瞰宮古島全島、伊良部島與周圍珊瑚礁的360度壯觀景色。","lat":24.7948,"lng":125.3418,"googleMapsUrl":"https://maps.google.com/maps?q=24.7948,125.3418","indoor":false,"tags":[],"mediaCount":0,"mediaSourceUrl":null,"rating":null,"admissionFree":null,"triggerRadiusM":75.0},{"id":"jp-miyakojima-botanical-bingata","title":"紅型染色體驗工房","summary":"紅型（Bingata）是源自琉球王朝的傳統防染染色工藝，以鮮豔的珊瑚色、海藍色描繪熱帶花鳥圖案，宮古島各工房提供親手製作手巾或扇子的體驗課程，是最受台灣旅客歡迎的文化活動之一。","lat":24.800128,"lng":125.31566,"googleMapsUrl":"https://maps.google.com/maps?q=24.800128,125.31566","indoor":true,"tags":[],"mediaCount":0,"mediaSourceUrl":null,"rating":null,"admissionFree":null,"triggerRadiusM":75.0},{"id":"jp-miyakojima-city-museum","title":"宮古島市総合博物館","summary":"宮古島市唯一的綜合博物館，完整呈現宮古諸島的自然史、考古遺址與惡名昭彰的人頭稅制度。館內典藏傳統苧麻織品等珍貴工藝，是認識宮古文化不可錯過的起點。","lat":24.796933,"lng":125.317688,"googleMapsUrl":"https://maps.google.com/maps?q=24.796933,125.317688","indoor":true,"tags":[],"mediaCount":0,"mediaSourceUrl":null,"rating":null,"admissionFree":null,"triggerRadiusM":75.0},{"id":"jp-miyakojima-coral-restoration","title":"宮古島珊瑚礁再生プロジェクト","summary":"宮古島珊瑚礁復育計畫是應對珊瑚白化危機的在地行動，設有展示設施介紹珊瑚斷枝移植技術與海洋生態保育科學，部分活動開放遊客參與實作。","lat":24.806,"lng":125.285,"googleMapsUrl":"https://maps.google.com/maps?q=24.806,125.285","indoor":false,"tags":[],"mediaCount":0,"mediaSourceUrl":null,"rating":null,"admissionFree":null,"triggerRadiusM":75.0},{"id":"jp-miyakojima-funasugi-banata","title":"フナウサギバナタ","summary":"フナウサギバナタ是伊良部島北端的一處海崖展望台，宮古語意為「送別遠行船隻之端」，崖頂矗立著一尊凝視遠洋的石雕女子像，承載著漁村女性盼夫歸來的千年深情。","lat":24.8613796,"lng":125.1780562,"googleMapsUrl":"https://maps.google.com/maps?q=24.8613796,125.1780562","indoor":false,"tags":[],"mediaCount":0,"mediaSourceUrl":null,"rating":null,"admissionFree":null,"triggerRadiusM":75.0},{"id":"jp-miyakojima-harimizu-utaki","title":"漲水御嶽","summary":"漲水御嶽是宮古島最神聖的御嶽（聖林）之一，數百年來是島民舉行祈雨、豐年祭等儀式的靈性中心，在市區鬧中取靜，至今仍供奉香火。","lat":24.807268,"lng":125.27951,"googleMapsUrl":"https://maps.google.com/maps?q=24.807268,125.27951","indoor":false,"tags":[],"mediaCount":0,"mediaSourceUrl":null,"rating":null,"admissionFree":null,"triggerRadiusM":75.0},{"id":"jp-miyakojima-head-tax-stone","title":"人頭税石","summary":"這塊石頭是薩摩藩統治時期人頭稅制度的歷史見證——凡身高超過此石的宮古島人皆須納稅，這項殘酷制度延續約兩百年，是宮古島人集體記憶中最沉重的傷痕之一。","lat":24.812617,"lng":125.281723,"googleMapsUrl":"https://maps.google.com/maps?q=24.812617,125.281723","indoor":false,"tags":[],"mediaCount":0,"mediaSourceUrl":null,"rating":null,"admissionFree":null,"triggerRadiusM":75.0},{"id":"jp-miyakojima-hennazaki-east","title":"東平安名崎","summary":"宮古島最東端的岬角，細長的珊瑚礁台地向海中延伸約2公里，燈塔矗立其上，三面臨海的壯闊視野是宮古島最震撼的自然景觀之一。","lat":24.7189,"lng":125.4693,"googleMapsUrl":"https://maps.google.com/maps?q=24.7189,125.4693","indoor":false,"tags":[],"mediaCount":0,"mediaSourceUrl":null,"rating":null,"admissionFree":null,"triggerRadiusM":100.0},{"id":"jp-miyakojima-hora-cave","title":"保良泉鍾乳洞","summary":"保良泉鍾乳洞是宮古島東南部保良地區的石灰岩洞穴，洞內有精緻的石筍與鐘乳石地質景觀，附設浮潛設施，是宮古島少數可深入地底探索的自然體驗。","lat":24.7302,"lng":125.432,"googleMapsUrl":"https://maps.google.com/maps?q=24.7302,125.432","indoor":false,"tags":[],"mediaCount":0,"mediaSourceUrl":null,"rating":null,"admissionFree":null,"triggerRadiusM":75.0},{"id":"jp-miyakojima-hora-spring","title":"保良泉","summary":"保良泉是宮古島南岸的天然淡水湧泉奇景，泉水在海岸邊與海水交會，形成可入內探索的鐘乳石洞穴，並提供絕佳的海岸浮潛體驗。","lat":24.7302,"lng":125.432,"googleMapsUrl":"https://maps.google.com/maps?q=24.7302,125.432","indoor":false,"tags":[],"mediaCount":0,"mediaSourceUrl":null,"rating":null,"admissionFree":null,"triggerRadiusM":75.0},{"id":"jp-miyakojima-ikema-beach","title":"池間島ビーチ","summary":"池間島北岸的沙灘水淺浪靜，是宮古島周邊離島中最適合浮潛的海灘之一，珊瑚礁緊鄰海岸，熱帶魚種豐富，海草床亦是觀察儒艮覓食痕跡的最佳位置。","lat":24.9374,"lng":125.2453,"googleMapsUrl":"https://maps.google.com/maps?q=24.9374,125.2453","indoor":false,"tags":[],"mediaCount":0,"mediaSourceUrl":null,"rating":null,"admissionFree":null,"triggerRadiusM":75.0},{"id":"jp-miyakojima-ikema-bridge","title":"池間大橋","summary":"全長1,425公尺，連接宮古島北端與池間島，橋上可以欣賞宮古島西北海域最鮮豔的淺海藍綠色調，是日落攝影的熱門地點。","lat":24.91889,"lng":125.26194,"googleMapsUrl":"https://maps.google.com/maps?q=24.91889,125.26194","indoor":false,"tags":[],"mediaCount":0,"mediaSourceUrl":null,"rating":null,"admissionFree":null,"triggerRadiusM":150.0},{"id":"jp-miyakojima-ikema-dugong","title":"池間島ジュゴン生息域","summary":"池間島周邊海域是宮古群島中已確認儒艮（海牛）存在的唯一區域，環境省列為重要保護海域，偶有目擊報告，是日本境內難得一見的哺乳類海洋動物棲息環境。","lat":24.905,"lng":125.173,"googleMapsUrl":"https://maps.google.com/maps?q=24.905,125.173","indoor":false,"tags":[],"mediaCount":0,"mediaSourceUrl":null,"rating":null,"admissionFree":null,"triggerRadiusM":75.0},{"id":"jp-miyakojima-ikema-island","title":"池間島","summary":"池間島是透過池間大橋與宮古島北端相連的小島，面積僅約2.83平方公里，以周邊海域可能出沒的儒艮（海牛）和傳統漁村風情聞名，是宮古島旅行中最具靜謐感的離島之一。","lat":24.9292515,"lng":125.243599,"googleMapsUrl":"https://maps.google.com/maps?q=24.9292515,125.243599","indoor":false,"tags":[],"mediaCount":0,"mediaSourceUrl":null,"rating":null,"admissionFree":null,"triggerRadiusM":500.0},{"id":"jp-miyakojima-ikema-wetland","title":"池間湿地","summary":"池間濕地是列入拉姆薩公約的重要濕地，冬季候鳥雲集，是宮古島生態保育的象徵，也是賞鳥愛好者的朝聖地。","lat":24.9342,"lng":125.2458,"googleMapsUrl":"https://maps.google.com/maps?q=24.9342,125.2458","indoor":false,"tags":[],"mediaCount":0,"mediaSourceUrl":null,"rating":null,"admissionFree":null,"triggerRadiusM":75.0},{"id":"jp-miyakojima-irabu-bridge","title":"伊良部大橋","summary":"全長3,540公尺，2015年完工，是日本最長的免費通行橋梁，連接宮古島與伊良部島，橋面最高點約為海面上27公尺，兩側海景壯闊。","lat":24.7992,"lng":125.2333,"googleMapsUrl":"https://maps.google.com/maps?q=24.7992,125.2333","indoor":false,"tags":[],"mediaCount":0,"mediaSourceUrl":null,"rating":null,"admissionFree":null,"triggerRadiusM":200.0},{"id":"jp-miyakojima-irabu-diving","title":"伊良部島ダイビング","summary":"伊良部島與下地島之間的水道擁有世界頂級的漂流潛水條件，透明度常年維持35至40公尺以上，更以可從水面游入的「通り池」連通海中洞穴系統聞名，是讓全球潛水員慕名而來的深度潛水聖地。","lat":24.824028,"lng":125.136417,"googleMapsUrl":"https://maps.google.com/maps?q=24.824028,125.136417","indoor":false,"tags":[],"mediaCount":0,"mediaSourceUrl":null,"rating":null,"admissionFree":null,"triggerRadiusM":75.0},{"id":"jp-miyakojima-irabu-island","title":"伊良部島","summary":"伊良部島是宮古群島第二大島，2015年伊良部大橋落成後無需渡輪即可抵達。島上保留了深海漁業傳統與原始自然風光，是探索宮古離島文化的最佳起點。","lat":24.834388,"lng":125.186688,"googleMapsUrl":"https://maps.google.com/maps?q=24.834388,125.186688","indoor":false,"tags":[],"mediaCount":0,"mediaSourceUrl":null,"rating":null,"admissionFree":null,"triggerRadiusM":75.0},{"id":"jp-miyakojima-irabu-katsuobushi","title":"佐良浜かつお節文化","summary":"佐良濱是伊良部島東北角的傳統漁村，以深海遠洋鰹魚漁業聞名，村民世代乘木造船遠赴南洋捕撈鰹魚，再返家製作柴魚片。這套延續數百年的海洋文化至今仍是村落的靈魂。","lat":24.833,"lng":125.217,"googleMapsUrl":"https://maps.google.com/maps?q=24.833,125.217","indoor":false,"tags":[],"mediaCount":0,"mediaSourceUrl":null,"rating":null,"admissionFree":null,"triggerRadiusM":75.0},{"id":"jp-miyakojima-irabu-lighthouse","title":"伊良部島灯台","summary":"伊良部島灯台矗立於島嶼西端的珊瑚礁台地上，白色圓柱燈塔俯瞰東海，是引導往來宮古海峽船隻的重要航標，也是欣賞西海夕陽與無邊水平線的靜謐展望點。","lat":24.858,"lng":125.1152,"googleMapsUrl":"https://maps.google.com/maps?q=24.858,125.1152","indoor":false,"tags":[],"mediaCount":0,"mediaSourceUrl":null,"rating":null,"admissionFree":null,"triggerRadiusM":75.0},{"id":"jp-miyakojima-irabu-panorama","title":"伊良部大橋展望","summary":"從伊良部島側回望伊良部大橋，3,540公尺的橋身在宮古藍的海面上畫出一條優雅的弧線，是體驗這座「日本最長免費橋梁」全貌最震撼的角度，也是伊良部島最受歡迎的攝影構圖點之一。","lat":24.8148,"lng":125.1622,"googleMapsUrl":"https://maps.google.com/maps?q=24.8148,125.1622","indoor":false,"tags":[],"mediaCount":0,"mediaSourceUrl":null,"rating":null,"admissionFree":null,"triggerRadiusM":75.0},{"id":"jp-miyakojima-kaijin-no-mori","title":"海人の森","summary":"海人の森是宮古島難得一見的紅樹林濕地，設有木棧道供遊客步行其中，靜謐的水林環境展現宮古島鮮為人知的生態面貌。","lat":24.818,"lng":125.3168,"googleMapsUrl":"https://maps.google.com/maps?q=24.818,125.3168","indoor":false,"tags":[],"mediaCount":0,"mediaSourceUrl":null,"rating":null,"admissionFree":null,"triggerRadiusM":75.0},{"id":"jp-miyakojima-kamama-ridge-park","title":"カママ嶺公園","summary":"カママ嶺公園是宮古島市區附近的小山丘公園，提供俯瞰平良市街與遠海的視角，是當地居民散步健身與欣賞夕陽的熱門地點。","lat":24.7973591,"lng":125.2768616,"googleMapsUrl":"https://maps.google.com/maps?q=24.7973591,125.2768616","indoor":false,"tags":[],"mediaCount":0,"mediaSourceUrl":null,"rating":null,"admissionFree":null,"triggerRadiusM":75.0},{"id":"jp-miyakojima-kurima-bridge","title":"来間大橋","summary":"全長1,690公尺的来間大橋連接宮古島與来間島，橋面兩側視野開闊，可俯瞰宮古藍海水與前浜海灘的壯麗景色。1995年通車，是宮古島具代表性的跨海大橋之一。","lat":24.7258527,"lng":125.2643988,"googleMapsUrl":"https://maps.google.com/maps?q=24.7258527,125.2643988","indoor":false,"tags":[],"mediaCount":0,"mediaSourceUrl":null,"rating":null,"admissionFree":null,"triggerRadiusM":75.0},{"id":"jp-miyakojima-kurima-island","title":"来間島","summary":"来間島是宮古島西南方一座安靜的小島，面積約2.84平方公里，以甘蔗田、珊瑚礁海灘和崖頂咖啡廳著稱，是宮古島鬧中取靜的單車旅遊首選。","lat":24.7224,"lng":125.247,"googleMapsUrl":"https://maps.google.com/maps?q=24.7224,125.247","indoor":false,"tags":[],"mediaCount":0,"mediaSourceUrl":null,"rating":null,"admissionFree":null,"triggerRadiusM":75.0},{"id":"jp-miyakojima-kurima-nagama-beach","title":"長間浜","summary":"長間浜是来間島南岸的一片原始白沙灘，因地處偏僻而少有觀光客，海水清澈見底、沙粒細白如粉，被譽為宮古島最秘境的海灘之一。","lat":24.725968,"lng":125.239806,"googleMapsUrl":"https://maps.google.com/maps?q=24.725968,125.239806","indoor":false,"tags":[],"mediaCount":0,"mediaSourceUrl":null,"rating":null,"admissionFree":null,"triggerRadiusM":75.0},{"id":"jp-miyakojima-kurima-sugarcane","title":"来間島サトウキビ畑","summary":"来間島的道路兩旁遍布甘蔗田，是宮古島傳統農業景觀的縮影。每年11月至翌年3月為收成季節，可見農機穿梭於田間，感受南島農村的純樸生活節奏。","lat":24.7213,"lng":125.247,"googleMapsUrl":"https://maps.google.com/maps?q=24.7213,125.247","indoor":false,"tags":[],"mediaCount":0,"mediaSourceUrl":null,"rating":null,"admissionFree":null,"triggerRadiusM":75.0},{"id":"jp-miyakojima-kurima-viewpoint","title":"来間島龍宮城展望台","summary":"龍宮城展望台是来間島上一座造型獨特的三層樓觀景塔，頂層可360度鳥瞰與那霸前浜全景、来間大橋及宮古藍海色，是宮古島攝影打卡的最佳制高點。","lat":24.726,"lng":125.2516,"googleMapsUrl":"https://maps.google.com/maps?q=24.726,125.2516","indoor":false,"tags":[],"mediaCount":0,"mediaSourceUrl":null,"rating":null,"admissionFree":null,"triggerRadiusM":75.0},{"id":"jp-miyakojima-mango-orchard","title":"宮古マンゴー農園","summary":"宮古島是日本頂級芒果的主要產地，每年六至八月盛產期間，農園開放旅客直接入園採果品嚐，飽滿的「アーウィン」品種芒果在珊瑚礁土壤與充沛日照下熟成，甜度遠超市售進口品。","lat":24.7855,"lng":125.3282,"googleMapsUrl":"https://maps.google.com/maps?q=24.7855,125.3282","indoor":false,"tags":[],"mediaCount":0,"mediaSourceUrl":null,"rating":null,"admissionFree":null,"triggerRadiusM":75.0},{"id":"jp-miyakojima-maou-palace-cave","title":"魔王の宮殿（洞窟ダイビングスポット）","summary":"魔王の宮殿是宮古島最神秘的洞穴潛水點，由連串巨大石灰岩洞室組成，陽光從洞頂縫隙射入，在水中形成如大教堂般壯麗的光柱奇景。","lat":24.8277,"lng":125.1332,"googleMapsUrl":"https://maps.google.com/maps?q=24.8277,125.1332","indoor":false,"tags":[],"mediaCount":0,"mediaSourceUrl":null,"rating":null,"admissionFree":null,"triggerRadiusM":75.0},{"id":"jp-miyakojima-marine-park","title":"宮古島海中公園","summary":"日本少數設有水下觀察室的海洋公園，步道延伸至海中觀察室可在水面下直接觀察珊瑚礁與熱帶魚，無需潛水即能體驗海底世界。","lat":24.8787444,"lng":125.2747111,"googleMapsUrl":"https://maps.google.com/maps?q=24.8787444,125.2747111","indoor":true,"tags":[],"mediaCount":0,"mediaSourceUrl":null,"rating":null,"admissionFree":null,"triggerRadiusM":80.0},{"id":"jp-miyakojima-miyako-beef-ranch","title":"宮古牛農場","summary":"宮古島飼育的宮古牛（黑毛和牛）以海風吹拂的開闊牧場環境與低壓力放牧方式聞名，肉質油花細緻，是宮古島美食體驗中不可錯過的島產和牛。","lat":24.76,"lng":125.32,"googleMapsUrl":"https://maps.google.com/maps?q=24.76,125.32","indoor":false,"tags":[],"mediaCount":0,"mediaSourceUrl":null,"rating":null,"admissionFree":null,"triggerRadiusM":75.0},{"id":"jp-miyakojima-miyako-festival","title":"宮古島まつり（クルバガー）","summary":"宮古島まつり是每年十月舉辦的全島最大傳統節慶，以傳統木舟競渡「クルバガー」為核心，結合武術展演、民謠歌舞與地方食市，是體驗宮古島島民生活文化的最佳時機。","lat":24.8062,"lng":125.282,"googleMapsUrl":"https://maps.google.com/maps?q=24.8062,125.282","indoor":false,"tags":[],"mediaCount":0,"mediaSourceUrl":null,"rating":null,"admissionFree":null,"triggerRadiusM":75.0},{"id":"jp-miyakojima-miyako-horse","title":"宮古馬","summary":"宮古馬是日本八大在來馬之一，體型小巧、性格溫馴，千年來生活在宮古諸島的牧草地上。伊良部島上設有牧場可近距離接觸這種珍稀原生馬種，是了解宮古島農耕文化的難得體驗。","lat":24.7684415,"lng":125.3110765,"googleMapsUrl":"https://maps.google.com/maps?q=24.7684415,125.3110765","indoor":false,"tags":[],"mediaCount":0,"mediaSourceUrl":null,"rating":null,"admissionFree":null,"triggerRadiusM":75.0},{"id":"jp-miyakojima-miyako-shrine","title":"宮古神社","summary":"創建於1590年的宮古神社是島上歷史最悠久的神社，主祀漁業與航海守護神，數百年來一直是宮古島漁民與居民的精神寄託。","lat":24.807767,"lng":125.280436,"googleMapsUrl":"https://maps.google.com/maps?q=24.807767,125.280436","indoor":false,"tags":[],"mediaCount":0,"mediaSourceUrl":null,"rating":null,"admissionFree":null,"triggerRadiusM":75.0},{"id":"jp-miyakojima-miyako-soba","title":"古謝そば屋（宮古そば）","summary":"創業逾九十年、宮古島最具歷史的老字號そば店，供應以豬骨和鰹魚熬製的清湯搭配手工圓麵條的道地宮古そば，是感受宮古島飲食文化根源的必訪之地。","lat":24.7905075,"lng":125.2843943,"googleMapsUrl":"https://maps.google.com/maps?q=24.7905075,125.2843943","indoor":true,"tags":[],"mediaCount":0,"mediaSourceUrl":null,"rating":null,"admissionFree":null,"triggerRadiusM":75.0},{"id":"jp-miyakojima-miyako-traditional-textile","title":"宮古上布","summary":"宮古上布是日本指定重要無形文化財的手工苧麻織品，以細如髮絲的苧麻纖維手紡後在石上砑染，呈現獨特的深藍靛色光澤，是宮古島最具代表性的傳統工藝。","lat":24.7691,"lng":125.3231,"googleMapsUrl":"https://maps.google.com/maps?q=24.7691,125.3231","indoor":true,"tags":[],"mediaCount":0,"mediaSourceUrl":null,"rating":null,"admissionFree":null,"triggerRadiusM":75.0},{"id":"jp-miyakojima-nakanoshima-channel","title":"中の島チャンネル（ダイビングスポット）","summary":"中の島水道是宮古島最著名的漂流潛水地點，強勁的潮流帶著潛水員穿越宮古本島與中之島之間的窄窄水道，能見度可達四十公尺以上。","lat":24.8135,"lng":125.1453,"googleMapsUrl":"https://maps.google.com/maps?q=24.8135,125.1453","indoor":false,"tags":[],"mediaCount":0,"mediaSourceUrl":null,"rating":null,"admissionFree":null,"triggerRadiusM":100.0},{"id":"jp-miyakojima-nakazone-tomb","title":"仲宗根豊見親の墓","summary":"建於16世紀初期的仲宗根豊見親之墓，是宮古島保存最完整的琉球時代石造墓葬，見證了宮古島統一歷史與琉球建築工藝，已指定為國家重要文化財。","lat":24.8089,"lng":125.2799,"googleMapsUrl":"https://maps.google.com/maps?q=24.8089,125.2799","indoor":false,"tags":[],"mediaCount":0,"mediaSourceUrl":null,"rating":null,"admissionFree":null,"triggerRadiusM":75.0},{"id":"jp-miyakojima-nishi-hennazaki","title":"西平安名崎","summary":"宮古島西北端的岬角，以白色風力發電機矗立於珊瑚礁海岸線著稱，是宮古島欣賞夕陽西沉入海的最佳地點之一。","lat":24.90951,"lng":125.25726,"googleMapsUrl":"https://maps.google.com/maps?q=24.90951,125.25726","indoor":false,"tags":[],"mediaCount":0,"mediaSourceUrl":null,"rating":null,"admissionFree":null,"triggerRadiusM":100.0},{"id":"jp-miyakojima-nishizato-market","title":"西里公設市場","summary":"宮古島市中心的傳統公設市場，攤位上陳列著當天早晨捕撈的新鮮魚獲、在地蔬果與宮古特產，是感受島民日常生活與飲食文化的最佳場所。","lat":24.8038,"lng":125.279,"googleMapsUrl":"https://maps.google.com/maps?q=24.8038,125.279","indoor":true,"tags":[],"mediaCount":0,"mediaSourceUrl":null,"rating":null,"admissionFree":null,"triggerRadiusM":75.0},{"id":"jp-miyakojima-ogami-island","title":"大神島","summary":"大神島是宮古島東北方的神聖小島，禁止任何機動車輛進入，僅可搭渡輪抵達，島上存在嚴格的聖地禁忌，部分區域連當地居民也不得踏入，是宮古群島中靈性氛圍最濃厚的秘境。","lat":24.915981,"lng":125.3079275,"googleMapsUrl":"https://maps.google.com/maps?q=24.915981,125.3079275","indoor":false,"tags":[],"mediaCount":0,"mediaSourceUrl":null,"rating":null,"admissionFree":null,"triggerRadiusM":200.0},{"id":"jp-miyakojima-painagama-beach","title":"パイナガマビーチ","summary":"距離宮古島市中心步行僅五分鐘的城市海灘，弧形白沙灘搭配平靜透明的淺海，是最方便攜家帶眷享受宮古海水的地點，設施完善且全年免費開放。","lat":24.8028,"lng":125.2713,"googleMapsUrl":"https://maps.google.com/maps?q=24.8028,125.2713","indoor":false,"tags":[],"mediaCount":0,"mediaSourceUrl":null,"rating":null,"admissionFree":null,"triggerRadiusM":75.0},{"id":"jp-miyakojima-sarahama-port","title":"佐良浜漁港","summary":"佐良浜漁港是宮古島伊良部島上歷史悠久的鰹魚漁業重鎮，保留著傳統漁村聚落風貌，是感受琉球離島生活文化的真實場景。","lat":24.8382,"lng":125.214,"googleMapsUrl":"https://maps.google.com/maps?q=24.8382,125.214","indoor":false,"tags":[],"mediaCount":0,"mediaSourceUrl":null,"rating":null,"admissionFree":null,"triggerRadiusM":75.0},{"id":"jp-miyakojima-sawada-beach","title":"佐和田の浜","summary":"佐和田の浜是伊良部島西岸一片廣闊的潮間帶海灘，以退潮後綿延散布於沙灘上的百餘塊巨礁怪石聞名，壯觀景致令人想起宮崎駿筆下的奇幻世界，是宮古島最具辨識度的攝影景點之一。","lat":24.8361,"lng":125.1603,"googleMapsUrl":"https://maps.google.com/maps?q=24.8361,125.1603","indoor":false,"tags":[],"mediaCount":0,"mediaSourceUrl":null,"rating":null,"admissionFree":null,"triggerRadiusM":75.0},{"id":"jp-miyakojima-sea-kayak-mangrove","title":"島尻マングローブ シーカヤック","summary":"宮古島南端的島尻地區有一片紅樹林水道，搭乘海上獨木舟穿梭其間，可近距離觀察蒼鷺、招潮蟹與各種潮間帶生物，是兼具趣味與生態的體驗行程。","lat":24.8777,"lng":125.2884,"googleMapsUrl":"https://maps.google.com/maps?q=24.8777,125.2884","indoor":false,"tags":[],"mediaCount":0,"mediaSourceUrl":null,"rating":null,"admissionFree":null,"triggerRadiusM":100.0},{"id":"jp-miyakojima-sea-turtle-yoshino","title":"吉野海岸（ウミガメ遭遇スポット）","summary":"吉野海岸的淺礁區是宮古島最容易近距離相遇綠蠵龜的地點，大片海草床吸引多隻海龜定期在此覓食，浮潛客常有與海龜並肩同游的珍貴體驗。","lat":24.748698,"lng":125.442441,"googleMapsUrl":"https://maps.google.com/maps?q=24.748698,125.442441","indoor":false,"tags":[],"mediaCount":0,"mediaSourceUrl":null,"rating":null,"admissionFree":null,"triggerRadiusM":100.0},{"id":"jp-miyakojima-shimajiri-beach","title":"前浜東岸","summary":"前浜海灘東段是與那霸前浜7公里長沙灘的較安靜區域，遊客較少，是欣賞宮古島日出的絕佳地點，清晨時分金色光芒映照在宮古藍海面上景色迷人。","lat":24.73472,"lng":125.26278,"googleMapsUrl":"https://maps.google.com/maps?q=24.73472,125.26278","indoor":false,"tags":[],"mediaCount":0,"mediaSourceUrl":null,"rating":null,"admissionFree":null,"triggerRadiusM":75.0},{"id":"jp-miyakojima-shimajiri-uganzaki","title":"島尻のマングローブ林","summary":"島尻紅樹林是宮古島南部最大的紅樹林濕地，可乘坐獨木舟深入林中水道，是感受宮古島熱帶生態系的沉浸式體驗。","lat":24.8778,"lng":125.2885,"googleMapsUrl":"https://maps.google.com/maps?q=24.8778,125.2885","indoor":false,"tags":[],"mediaCount":0,"mediaSourceUrl":null,"rating":null,"admissionFree":null,"triggerRadiusM":75.0},{"id":"jp-miyakojima-shimoji-airport","title":"下地島空港","summary":"下地島空港擁有全長3,000公尺的跑道，自1979年起長期作為全日空與日本航空飛行員技術審查的訓練機場，近年轉型為國際定期航班起降點，旅客大廳設計融入宮古島海洋元素，是探訪下地島的主要門戶。","lat":24.8268,"lng":125.1448,"googleMapsUrl":"https://maps.google.com/maps?q=24.8268,125.1448","indoor":false,"tags":[],"mediaCount":0,"mediaSourceUrl":null,"rating":null,"admissionFree":null,"triggerRadiusM":150.0},{"id":"jp-miyakojima-shimoji-cave-dive","title":"下地島洞窟ダイビング入口","summary":"下地島西岸的洞窟潛水入水點，是通往通り池地下洞穴系統的海面開口，潛水員從這個蔚藍海洞入水後，可穿越水下岩洞連通至兩個內陸水池，是宮古島最刺激的地形潛水體驗起點。","lat":24.824028,"lng":125.136417,"googleMapsUrl":"https://maps.google.com/maps?q=24.824028,125.136417","indoor":false,"tags":[],"mediaCount":0,"mediaSourceUrl":null,"rating":null,"admissionFree":null,"triggerRadiusM":75.0},{"id":"jp-miyakojima-shimoji-island","title":"下地島","summary":"下地島是緊鄰伊良部島南側的小島，以全長3,000公尺的訓練用跑道聞名，長年是日本航空公司飛行員技術測驗的聖地，近年更開闢國際定期航班，島嶼四周珊瑚礁環繞。","lat":24.81611,"lng":125.15694,"googleMapsUrl":"https://maps.google.com/maps?q=24.81611,125.15694","indoor":false,"tags":[],"mediaCount":0,"mediaSourceUrl":null,"rating":null,"admissionFree":null,"triggerRadiusM":500.0},{"id":"jp-miyakojima-shiratorisaki","title":"白鳥崎","summary":"白鳥崎是伊良部島最北端的海岬，設有白色燈塔一座，站在岬角可將東海與宮古海峽的遼闊海景盡收眼底，是島上少有的360度環繞視野展望地點。","lat":24.8636,"lng":125.1696,"googleMapsUrl":"https://maps.google.com/maps?q=24.8636,125.1696","indoor":false,"tags":[],"mediaCount":0,"mediaSourceUrl":null,"rating":null,"admissionFree":null,"triggerRadiusM":75.0},{"id":"jp-miyakojima-snorkel-rental","title":"パイナガマ海水浴場 レンタル拠点","summary":"鄰近宮古島市區的パイナガマ（Painagama）海灘是最方便的市區海灘，海灘沿線設有浮潛裝備與沙灘用品租借站，提供防寒衣、蛙鏡、呼吸管、腳蹼等全套配備，是不攜帶個人器材的訪客進入宮古海域的起跑點。","lat":24.8028,"lng":125.2713,"googleMapsUrl":"https://maps.google.com/maps?q=24.8028,125.2713","indoor":false,"tags":[],"mediaCount":0,"mediaSourceUrl":null,"rating":null,"admissionFree":null,"triggerRadiusM":75.0},{"id":"jp-miyakojima-south-wall","title":"サウスウォール（ダイビングスポット）","summary":"サウスウォールは宮古島南岸的垂直峭壁潛水點，礁壁從水面直墜超過四十公尺深，大型魚群與海扇密布，是宮古島壁潛愛好者的朝聖之地。","lat":24.6948,"lng":125.3048,"googleMapsUrl":"https://maps.google.com/maps?q=24.6948,125.3048","indoor":false,"tags":[],"mediaCount":0,"mediaSourceUrl":null,"rating":null,"admissionFree":null,"triggerRadiusM":100.0},{"id":"jp-miyakojima-sunagawa-utaki","title":"砂川御嶽","summary":"砂川御嶽是宮古島砂川地區一處傳統琉球聖地，密林中的石灰岩聖壇保留著宮古島原住民信仰的核心精神，是感受宮古島古老宗教文化的重要場所。","lat":24.7485,"lng":125.2918,"googleMapsUrl":"https://maps.google.com/maps?q=24.7485,125.2918","indoor":false,"tags":[],"mediaCount":0,"mediaSourceUrl":null,"rating":null,"admissionFree":null,"triggerRadiusM":75.0},{"id":"jp-miyakojima-sunayama-beach","title":"砂山ビーチ（砂山海灘）","summary":"以巨大天然拱形岩石聞名的秘境海灘，穿越拱岩後是一片安靜的珊瑚沙灣，拱岩本身是宮古島最具辨識度的自然地標之一。","lat":24.839485,"lng":125.280581,"googleMapsUrl":"https://maps.google.com/maps?q=24.839485,125.280581","indoor":false,"tags":[],"mediaCount":0,"mediaSourceUrl":null,"rating":null,"admissionFree":null,"triggerRadiusM":100.0},{"id":"jp-miyakojima-sunayama-sunset","title":"砂山展望台（日落景點）","summary":"砂山海灘上方的丘陵展望台是宮古島本島最佳的夕陽觀賞地點，居高臨下可同時看見砂山灣的天然岩拱、蔚藍珊瑚礁海以及西沉於東海的橙金日落，是攝影愛好者必訪的黃金時刻聖地。","lat":24.8395,"lng":125.2806,"googleMapsUrl":"https://maps.google.com/maps?q=24.8395,125.2806","indoor":false,"tags":[],"mediaCount":0,"mediaSourceUrl":null,"rating":null,"admissionFree":null,"triggerRadiusM":75.0},{"id":"jp-miyakojima-sunset-cruise","title":"宮古島サンセットクルーズ","summary":"搭乘玻璃底船或帆船雙體船出海，在來間島與砂山海岸周邊的海域欣賞宮古島醉人的落日，是當地最受歡迎的浪漫黃昏體驗行程。","lat":24.801,"lng":125.2755,"googleMapsUrl":"https://maps.google.com/maps?q=24.801,125.2755","indoor":false,"tags":[],"mediaCount":0,"mediaSourceUrl":null,"rating":null,"admissionFree":null,"triggerRadiusM":75.0},{"id":"jp-miyakojima-toguchi-beach","title":"渡口の浜","summary":"渡口の浜是伊良部島南岸的明星海灘，以潔白細緻的珊瑚沙與湛藍清澈的海水聞名，被譽為沖縄最美海灘之一。海灘兩端矗立的奇岩巨石更為這片風景增添獨特的戲劇張力。","lat":24.8115325,"lng":125.1779407,"googleMapsUrl":"https://maps.google.com/maps?q=24.8115325,125.1779407","indoor":false,"tags":[],"mediaCount":0,"mediaSourceUrl":null,"rating":null,"admissionFree":null,"triggerRadiusM":75.0},{"id":"jp-miyakojima-tomori-utaki","title":"友利御嶽","summary":"友利御嶽是宮古島西部友利地區最重要的琉球傳統聖域，千百年來是島民祈雨、農耕祭祀的精神核心。茂密的聖林與石灰岩祭壇至今仍保有濃厚的靈氣，是感受宮古島原始信仰文化的珍貴場所。","lat":24.7582,"lng":125.3128,"googleMapsUrl":"https://maps.google.com/maps?q=24.7582,125.3128","indoor":false,"tags":[],"mediaCount":0,"mediaSourceUrl":null,"rating":null,"admissionFree":null,"triggerRadiusM":75.0},{"id":"jp-miyakojima-toriki-ike-pools","title":"通り池","summary":"下地島西岸的通り池是兩個與海洋地下相連的天然內陸水池，潛水員可從水下洞穴在兩池之間穿越，被列為日本最具震撼力的地形潛水勝地之一，地面上亦可免費欣賞神秘深藍水色。","lat":24.8242599,"lng":125.1368284,"googleMapsUrl":"https://maps.google.com/maps?q=24.8242599,125.1368284","indoor":false,"tags":[],"mediaCount":0,"mediaSourceUrl":null,"rating":null,"admissionFree":null,"triggerRadiusM":75.0},{"id":"jp-miyakojima-tropical-botanical-garden","title":"宮古島市熱帯植物園","summary":"宮古島市熱帶植物園收集超過一千種熱帶植物，是宮古島市區少見的綠色休憩空間，適合親子同遊與靜態漫步。","lat":24.8002448,"lng":125.315929,"googleMapsUrl":"https://maps.google.com/maps?q=24.8002448,125.315929","indoor":false,"tags":[],"mediaCount":0,"mediaSourceUrl":null,"rating":null,"admissionFree":null,"triggerRadiusM":75.0},{"id":"jp-miyakojima-ueno-german-village","title":"ドイツ文化村","summary":"宮古島上巴伐利亞風格的建築群，源自1873年宮古島漁民英勇救助德國遇難船員的真實歷史，以異國風情建築訴說一段跨越文化的人道故事。","lat":24.7193,"lng":125.3226,"googleMapsUrl":"https://maps.google.com/maps?q=24.7193,125.3226","indoor":false,"tags":[],"mediaCount":0,"mediaSourceUrl":null,"rating":null,"admissionFree":null,"triggerRadiusM":75.0},{"id":"jp-miyakojima-yabiji-reef","title":"八重干瀬（ヤビジ）","summary":"八重干瀬是日本最大的珊瑚礁環礁，每逢大潮低潮時礁盤露出水面，形成壯觀的「幻之島」景象。需搭乘船隻前往，是宮古島海洋體驗的頂級行程。","lat":24.9975,"lng":125.2656,"googleMapsUrl":"https://maps.google.com/maps?q=24.9975,125.2656","indoor":false,"tags":[],"mediaCount":0,"mediaSourceUrl":null,"rating":null,"admissionFree":null,"triggerRadiusM":200.0},{"id":"jp-miyakojima-yonaha-maehama","title":"与那覇前浜","summary":"多次榮獲日本最美海灘評比第一的白沙灘，長達7公里的細白沙與透明碧藍海水讓人難以置信這是真實存在的景色。","lat":24.67648,"lng":125.25637,"googleMapsUrl":"https://maps.google.com/maps?q=24.67648,125.25637","indoor":false,"tags":[],"mediaCount":0,"mediaSourceUrl":null,"rating":null,"admissionFree":null,"triggerRadiusM":150.0},{"id":"jp-miyakojima-yoshino-coast","title":"吉野海岸","summary":"吉野海岸是日本數一數二的浮潛聖地，近岸即有密集珊瑚礁群，海龜出沒頻繁，透明度極高的海水讓水中世界一覽無遺。","lat":24.7485,"lng":125.4422,"googleMapsUrl":"https://maps.google.com/maps?q=24.7485,125.4422","indoor":false,"tags":[],"mediaCount":0,"mediaSourceUrl":null,"rating":null,"admissionFree":null,"triggerRadiusM":75.0},{"id":"jp-miyakojima-yukishio-factory","title":"雪塩製塩所","summary":"雪塩製塩所利用宮古島獨特的珊瑚礁石灰岩地層過濾海水，生產出世界最高礦物質含量的天然海鹽之一，工廠導覽搭配試吃體驗已成為宮古島最受歡迎的觀光工廠。","lat":24.902215,"lng":125.268416,"googleMapsUrl":"https://maps.google.com/maps?q=24.902215,125.268416","indoor":false,"tags":[],"mediaCount":0,"mediaSourceUrl":null,"rating":null,"admissionFree":null,"triggerRadiusM":75.0}]},{"packId":"tw-hsinchu","title":"新竹市","subtitle":"風城歷史與自然","version":"1.0.5","region":{"countryCode":"TW","countryName":"台灣","adminAreaLevel1":"新竹市"},"points":[{"id":"tw-hsinchu-bamboo-culture","title":"新竹竹文化工藝","summary":"新竹「竹」字得名於遍布早期平原的竹林，數百年竹材加工傳統孕育出從農具到藝術品的完整竹工藝體系。","lat":24.8062,"lng":120.9698,"googleMapsUrl":"https://maps.google.com/maps?q=24.8062,120.9698","indoor":false,"tags":[],"mediaCount":0,"mediaSourceUrl":null,"rating":null,"admissionFree":null,"triggerRadiusM":75.0},{"id":"tw-hsinchu-beimen-old-street","title":"北門街老街","summary":"北門街是新竹市逾兩百年歷史的老商業街，香鋪、中藥行、紙燈籠坊錯落其間，保留了竹塹城最鮮活的傳統商業記憶。","lat":24.8078,"lng":120.9688,"googleMapsUrl":"https://maps.google.com/maps?q=24.8078,120.9688","indoor":false,"tags":[],"mediaCount":0,"mediaSourceUrl":null,"rating":null,"admissionFree":null,"triggerRadiusM":75.0},{"id":"tw-hsinchu-catholic-church","title":"新竹天主堂（聖若瑟主教座堂）","summary":"建於1950年代的哥德式風格主教座堂，是台灣西部天主教社群的重要信仰中心，高聳的雙塔鐘樓是新竹市天際線的獨特座標。","lat":24.8093929,"lng":120.9668426,"googleMapsUrl":"https://maps.google.com/maps?q=24.8093929,120.9668426","indoor":false,"tags":[],"mediaCount":0,"mediaSourceUrl":null,"rating":null,"admissionFree":null,"triggerRadiusM":75.0},{"id":"tw-hsinchu-cinema-museum","title":"新竹市影像博物館","summary":"建於1933年的裝飾藝術風格戲院建築，曾是全台第一座有冷氣的戲院，現為保存台灣電影文化記憶的影像博物館。","lat":24.8049,"lng":120.9696,"googleMapsUrl":"https://maps.google.com/maps?q=24.8049,120.9696","indoor":true,"tags":[],"mediaCount":0,"mediaSourceUrl":null,"rating":null,"admissionFree":null,"triggerRadiusM":75.0},{"id":"tw-hsinchu-city-art-museum","title":"新竹市美術館","summary":"座落於1936年日治時期菸酒公賣局舊廳舍的市立美術館，以歷史建築空間承載當代藝術展覽，是新竹文化地景的重要一環。","lat":24.8063,"lng":120.9701,"googleMapsUrl":"https://maps.google.com/maps?q=24.8063,120.9701","indoor":true,"tags":[],"mediaCount":0,"mediaSourceUrl":null,"rating":null,"admissionFree":null,"triggerRadiusM":75.0},{"id":"tw-hsinchu-city-god-temple-snack","title":"城隍廟口小吃街","summary":"城隍廟前的小吃街是新竹美食的最高殿堂，肉圓、摔麵、貢丸湯與麻糬在此匯聚，是造訪新竹不可錯過的味覺朝聖地。","lat":24.8042,"lng":120.9661,"googleMapsUrl":"https://maps.google.com/maps?q=24.8042,120.9661","indoor":false,"tags":[],"mediaCount":0,"mediaSourceUrl":null,"rating":null,"admissionFree":null,"triggerRadiusM":75.0},{"id":"tw-hsinchu-city-god-temple","title":"新竹都城隍廟","summary":"建於1748年的清代廟宇，供奉官封「晉封台灣府城隍爺威靈公」，是全台地位最高的城隍廟之一，廟口小吃聞名全島。","lat":24.8043,"lng":120.9661,"googleMapsUrl":"https://maps.google.com/maps?q=24.8043,120.9661","indoor":true,"tags":[],"mediaCount":0,"mediaSourceUrl":null,"rating":null,"admissionFree":null,"triggerRadiusM":60.0},{"id":"tw-hsinchu-city-museum","title":"新竹市立博物館","summary":"新竹市立博物館以豐富的常設展呈現從道卡斯族原住民到清領、日治乃至當代的城市發展脈絡。展覽涵蓋文物、影像與互動裝置，是認識新竹歷史的最佳入口。","lat":24.8063,"lng":120.9701,"googleMapsUrl":"https://maps.google.com/maps?q=24.8063,120.9701","indoor":true,"tags":[],"mediaCount":0,"mediaSourceUrl":null,"rating":null,"admissionFree":null,"triggerRadiusM":75.0},{"id":"tw-hsinchu-coastal-park","title":"南寮海岸遊憩區","summary":"南寮海岸遊憩區擁有寬闊的沙灘與連綿沙丘，強勁的新竹風帶來絕佳的風箏衝浪與風浪板條件，是台灣最知名的風浪板運動海岸之一。","lat":24.846239,"lng":120.92589,"googleMapsUrl":"https://maps.google.com/maps?q=24.846239,120.92589","indoor":false,"tags":[],"mediaCount":0,"mediaSourceUrl":null,"rating":null,"admissionFree":null,"triggerRadiusM":75.0},{"id":"tw-hsinchu-confucius-temple","title":"新竹孔廟","summary":"建於清代的孔廟，現存建築為1874年重修後的格局，是新竹地區最重要的文教精神地標，每年教師節舉行傳統祭孔典禮。","lat":24.8000698,"lng":120.9780377,"googleMapsUrl":"https://maps.google.com/maps?q=24.8000698,120.9780377","indoor":false,"tags":[],"mediaCount":0,"mediaSourceUrl":null,"rating":null,"admissionFree":null,"triggerRadiusM":70.0},{"id":"tw-hsinchu-east-gate","title":"東門城（迎曦門）","summary":"建於1827年的清代城門，是新竹古城牆唯一留存至今的遺跡，也是這座城市最具代表性的地標。","lat":24.8031,"lng":120.97008,"googleMapsUrl":"https://maps.google.com/maps?q=24.8031,120.97008","indoor":false,"tags":[],"mediaCount":0,"mediaSourceUrl":null,"rating":null,"admissionFree":null,"triggerRadiusM":75.0},{"id":"tw-hsinchu-eighteen-peaks","title":"十八尖山","summary":"十八尖山是新竹市中心最重要的城市森林公園，由18座連綿丘陵組成，春季滿山遍野的山櫻花是全市最熱門的賞花勝地。","lat":24.7925323,"lng":120.9846069,"googleMapsUrl":"https://maps.google.com/maps?q=24.7925323,120.9846069","indoor":false,"tags":[],"mediaCount":0,"mediaSourceUrl":null,"rating":null,"admissionFree":null,"triggerRadiusM":75.0},{"id":"tw-hsinchu-glass-art-district","title":"玻璃工藝區","summary":"新竹玻璃工藝區聚集了多間工坊、畫廊與玻璃體驗工房，是全台最完整的玻璃產業聚落。遊客可在此觀賞職人吹製玻璃的精湛技藝，也能親手製作屬於自己的玻璃紀念品。","lat":24.8014,"lng":120.9781,"googleMapsUrl":"https://maps.google.com/maps?q=24.8014,120.9781","indoor":false,"tags":[],"mediaCount":0,"mediaSourceUrl":null,"rating":null,"admissionFree":null,"triggerRadiusM":75.0},{"id":"tw-hsinchu-glass-museum","title":"新竹市立玻璃工藝博物館","summary":"全台唯一以玻璃工藝為主題的博物館，館舍本身為1936年落成的日治時期官舍建築，收藏台灣及國際玻璃藝術精品。","lat":24.8014,"lng":120.9781,"googleMapsUrl":"https://maps.google.com/maps?q=24.8014,120.9781","indoor":true,"tags":[],"mediaCount":0,"mediaSourceUrl":null,"rating":null,"admissionFree":null,"triggerRadiusM":60.0},{"id":"tw-hsinchu-guandi-temple","title":"新竹關帝廟","summary":"新竹關帝廟主祀關聖帝君，是竹塹商業社群祈福許願的精神重心，每逢農曆節慶香火鼎盛、傳統儀式熱鬧非凡。","lat":24.802398,"lng":120.966654,"googleMapsUrl":"https://maps.google.com/maps?q=24.802398,120.966654","indoor":false,"tags":[],"mediaCount":0,"mediaSourceUrl":null,"rating":null,"admissionFree":null,"triggerRadiusM":75.0},{"id":"tw-hsinchu-harbor-canal","title":"港南運河","summary":"港南運河是連接新竹漁港與市區的歷史水道，兩岸設有平坦的自行車道，木造漁船靜靜停泊其間，構成一幅悠閒的水岸風情畫。","lat":24.822819,"lng":120.910339,"googleMapsUrl":"https://maps.google.com/maps?q=24.822819,120.910339","indoor":false,"tags":[],"mediaCount":0,"mediaSourceUrl":null,"rating":null,"admissionFree":null,"triggerRadiusM":75.0},{"id":"tw-hsinchu-longhegong-temple","title":"長和宮","summary":"建於清代乾隆年間的古廟，位於舊城南門一帶，是新竹市現存歷史最悠久的廟宇之一，主祀媽祖。","lat":24.808582,"lng":120.964876,"googleMapsUrl":"https://maps.google.com/maps?q=24.808582,120.964876","indoor":false,"tags":[],"mediaCount":0,"mediaSourceUrl":null,"rating":null,"admissionFree":null,"triggerRadiusM":75.0},{"id":"tw-hsinchu-matsu-temple","title":"新竹天后宮","summary":"新竹天后宮供奉海神媽祖，見證了竹塹港昔日的漁業與海運繁景，是新竹沿海移民信仰的精神寄託。","lat":24.800756,"lng":120.962166,"googleMapsUrl":"https://maps.google.com/maps?q=24.800756,120.962166","indoor":false,"tags":[],"mediaCount":0,"mediaSourceUrl":null,"rating":null,"admissionFree":null,"triggerRadiusM":75.0},{"id":"tw-hsinchu-mifun-culture","title":"新竹米粉文化","summary":"新竹是台灣米粉之都，獨特的九降風將細如髮絲的純米粉自然風乾，造就了全台無可複製的Q彈口感與清香滋味。","lat":24.8085,"lng":120.9645,"googleMapsUrl":"https://maps.google.com/maps?q=24.8085,120.9645","indoor":false,"tags":[],"mediaCount":0,"mediaSourceUrl":null,"rating":null,"admissionFree":null,"triggerRadiusM":75.0},{"id":"tw-hsinchu-military-village","title":"眷村博物館","summary":"新竹眷村博物館保存了1949年隨國民政府撤台的外省軍眷所建立的聚落樣貌，以文物、照片與口述歷史記錄這段動盪離散的近代史，是台灣族群融合歷程的重要見證。","lat":24.8140749,"lng":120.9667714,"googleMapsUrl":"https://maps.google.com/maps?q=24.8140749,120.9667714","indoor":true,"tags":[],"mediaCount":0,"mediaSourceUrl":null,"rating":null,"admissionFree":null,"triggerRadiusM":75.0},{"id":"tw-hsinchu-moat-park","title":"護城河親水公園","summary":"環繞新竹舊城區的護城河改建而成的帶狀公園，全長約1.8公里，是市民散步、騎單車的日常生活空間，也是認識新竹舊城輪廓的最佳路線。","lat":24.806471,"lng":120.968438,"googleMapsUrl":"https://maps.google.com/maps?q=24.806471,120.968438","indoor":false,"tags":[],"mediaCount":0,"mediaSourceUrl":null,"rating":null,"admissionFree":null,"triggerRadiusM":100.0},{"id":"tw-hsinchu-nanliaogang-port","title":"南寮漁港","summary":"南寮漁港是新竹市最主要的漁業基地，清晨漁船魚貨上岸熱鬧非凡，港邊聚集多家海鮮餐廳，以平價新鮮的漁港料理聞名。","lat":24.84694,"lng":120.9225,"googleMapsUrl":"https://maps.google.com/maps?q=24.84694,120.9225","indoor":false,"tags":[],"mediaCount":0,"mediaSourceUrl":null,"rating":null,"admissionFree":null,"triggerRadiusM":75.0},{"id":"tw-hsinchu-north-gate-street","title":"北門街","summary":"清代新竹城北門外的古商街，現存大量傳統閩南式街屋與老字號店舖，紅燈籠與古樸騎樓構成新竹最具歷史感的街道景致。","lat":24.8081,"lng":120.9652,"googleMapsUrl":"https://maps.google.com/maps?q=24.8081,120.9652","indoor":false,"tags":[],"mediaCount":0,"mediaSourceUrl":null,"rating":null,"admissionFree":null,"triggerRadiusM":75.0},{"id":"tw-hsinchu-park-zoo","title":"新竹公園暨動物園","summary":"創立於1921年的百年公園，園內附設的新竹市立動物園是台灣現存歷史最悠久的動物園，免費入場，保有舊式動物園的懷舊氛圍。","lat":24.801056,"lng":120.979472,"googleMapsUrl":"https://maps.google.com/maps?q=24.801056,120.979472","indoor":false,"tags":[],"mediaCount":0,"mediaSourceUrl":null,"rating":null,"admissionFree":null,"triggerRadiusM":120.0},{"id":"tw-hsinchu-prefecture-hall","title":"新竹州廳","summary":"1925年完工的日治時期巴洛克式行政建築，現為新竹市政府所在地，外立面的拱廊與綠色圓頂是台灣保存最完整的日殖民地官廳建築之一。","lat":24.8068,"lng":120.9688,"googleMapsUrl":"https://maps.google.com/maps?q=24.8068,120.9688","indoor":false,"tags":[],"mediaCount":0,"mediaSourceUrl":null,"rating":null,"admissionFree":null,"triggerRadiusM":80.0},{"id":"tw-hsinchu-qingcao-lake","title":"青草湖","summary":"青草湖是新竹市東郊山麓間的一座風光明媚水庫湖泊，湖岸設有步道與涼亭，遊客可租借腳踏船體驗湖上悠閒時光。","lat":24.7749,"lng":120.9709,"googleMapsUrl":"https://maps.google.com/maps?q=24.7749,120.9709","indoor":false,"tags":[],"mediaCount":0,"mediaSourceUrl":null,"rating":null,"admissionFree":null,"triggerRadiusM":75.0},{"id":"tw-hsinchu-science-park","title":"新竹科學工業園區","summary":"新竹科學工業園區是台灣半導體產業的心臟地帶，也是全球最重要的晶片製造聚落之一。園區設有免費遊客中心，以深入淺出的方式解說積體電路如何從沙子變成驅動現代世界的晶片。","lat":24.7823,"lng":121.0064,"googleMapsUrl":"https://maps.google.com/maps?q=24.7823,121.0064","indoor":false,"tags":[],"mediaCount":0,"mediaSourceUrl":null,"rating":null,"admissionFree":null,"triggerRadiusM":75.0},{"id":"tw-hsinchu-sports-park","title":"新竹市立體育場","summary":"新竹市立體育場是市中心最大的綜合運動公園，環形跑道旁綠草如茵，週末假日市集與運動人潮交織，展現新竹市民活躍的城市生活文化。","lat":24.8012867,"lng":120.9811473,"googleMapsUrl":"https://maps.google.com/maps?q=24.8012867,120.9811473","indoor":false,"tags":[],"mediaCount":0,"mediaSourceUrl":null,"rating":null,"admissionFree":null,"triggerRadiusM":75.0},{"id":"tw-hsinchu-train-station","title":"新竹火車站","summary":"建於1913年的日治時期巴洛克式車站，是台灣現存最美麗的古典主義火車站建築之一，至今仍持續運營。","lat":24.8012,"lng":120.9718,"googleMapsUrl":"https://maps.google.com/maps?q=24.8012,120.9718","indoor":false,"tags":[],"mediaCount":0,"mediaSourceUrl":null,"rating":null,"admissionFree":null,"triggerRadiusM":75.0},{"id":"tw-hsinchu-victory-park","title":"勝利公園","summary":"勝利公園是緊鄰新竹舊城區的歷史綠地，園內保存日治時期神社的石燈籠與基座遺跡，百年老榕樹氣根垂掛、樹冠遮天，是鬧市中難得的幽靜角落。","lat":24.8062,"lng":120.9668,"googleMapsUrl":"https://maps.google.com/maps?q=24.8062,120.9668","indoor":false,"tags":[],"mediaCount":0,"mediaSourceUrl":null,"rating":null,"admissionFree":null,"triggerRadiusM":75.0},{"id":"tw-hsinchu-wind-culture","title":"新竹風文化展示館","summary":"新竹是台灣本島最多風的城市，每逢秋冬便有九降風強勁橫掃，深刻影響在地飲食、建築與生活節奏。展示館以互動裝置解說風城性格的成因，並呈現風如何塑造米粉、貢丸、油紙傘等新竹特色文化。","lat":24.8045,"lng":120.9698,"googleMapsUrl":"https://maps.google.com/maps?q=24.8045,120.9698","indoor":true,"tags":[],"mediaCount":0,"mediaSourceUrl":null,"rating":null,"admissionFree":null,"triggerRadiusM":75.0},{"id":"tw-hsinchu-xiangshan-wetland","title":"香山濕地","summary":"香山濕地是台灣西海岸重要的潮間帶生態系，豐富的泥灘地孕育大量彈塗魚、招潮蟹與候鳥，木棧道讓遊客得以深入濕地核心觀察野生生態。","lat":24.7797076,"lng":120.9034147,"googleMapsUrl":"https://maps.google.com/maps?q=24.7797076,120.9034147","indoor":false,"tags":[],"mediaCount":0,"mediaSourceUrl":null,"rating":null,"admissionFree":null,"triggerRadiusM":75.0},{"id":"tw-hsinchu-zhulian-temple","title":"竹蓮寺","summary":"創建於清乾隆七年（1742年）的觀音廟，是新竹市歷史最悠久的佛寺，也是在地居民的重要精神信仰依歸。","lat":24.7998,"lng":120.9715,"googleMapsUrl":"https://maps.google.com/maps?q=24.7998,120.9715","indoor":false,"tags":[],"mediaCount":0,"mediaSourceUrl":null,"rating":null,"admissionFree":null,"triggerRadiusM":75.0},{"id":"tw-hsinchu-zhurenliyou-house","title":"鄭家古厝","summary":"鄭家古厝是新竹市保存完好的清代閩南式大宅，燕尾屋脊與精緻磚雕展現了竹塹望族的建築美學與工藝巔峰。","lat":24.81002,"lng":120.96532,"googleMapsUrl":"https://maps.google.com/maps?q=24.81002,120.96532","indoor":false,"tags":[],"mediaCount":0,"mediaSourceUrl":null,"rating":null,"admissionFree":null,"triggerRadiusM":75.0},{"id":"tw-hsinchucounty-beipu-old-street","title":"北埔老街","summary":"北埔老街是新竹縣保存最完整的客家歷史聚落，清代隘勇制度下形成的防禦性街廓至今仍可辨識。街道上販售客家擂茶、柿餅與粢粑等傳統食物，慈天宮香火鼎盛，每逢桐花季更是山城美景。","lat":24.6998,"lng":121.0584,"googleMapsUrl":"https://maps.google.com/maps?q=24.6998,121.0584","indoor":false,"tags":[],"mediaCount":0,"mediaSourceUrl":null,"rating":null,"admissionFree":null,"triggerRadiusM":75.0}]}]}